{
  "name": "bulk-image-optimiser",
  "version": "1.1.3",
  "description": "Free, private, in-browser bulk image optimiser — resize over 2000px and compress under 1MB. No uploads, no AI, no server.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22",
    "npm": ">=11"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "version": "node scripts/sync-version.mjs && git add -A",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:app": "vite build --config vite.config.app.ts && mv dist-app/app.html dist-app/index.html",
    "preview:app": "vite preview --config vite.config.app.ts --outDir dist-app",
    "test": "vitest run",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri"
  },
  "dependencies": {
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/resize": "^2.1.1",
    "@jsquash/webp": "^1.5.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "jszip": "^3.10.1",
    "libheif-js": "^1.19.8"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^26.0.0",
    "playwright": "^1.61.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
