{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Scalir",
  "version": "1.1.2",
  "identifier": "digital.shad.scalir",
  "build": {
    "frontendDist": "../dist-app",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:app"
  },
  "app": {
    "windows": [
      {
        "title": "Scalir — Bulk Image Optimiser",
        "width": 1100,
        "height": 800,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
